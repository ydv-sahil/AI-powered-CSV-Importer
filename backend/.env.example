# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. `.env` is gitignored — never commit a real key.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=4000

# Comma-separated origins, or * for any. Lock this down in production.
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# LLM. `gemini` is the default: free tier, no credit card.
# Get a key at https://aistudio.google.com/apikey
#
# Set `mock` to run the whole pipeline with a deterministic header-matching
# stub instead of a real model — useful for frontend work and for tests.
# ---------------------------------------------------------------------------

LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Alternative providers. Adapters are not implemented yet — see
# src/services/llm/types.ts for the interface to implement.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5

# ---------------------------------------------------------------------------
# Batching. Defaults are tuned for the Gemini free tier (15 requests/minute).
# Raise BATCH_CONCURRENCY on a paid key; lower BATCH_SIZE if you see MAX_TOKENS.
# ---------------------------------------------------------------------------

BATCH_SIZE=25
BATCH_CONCURRENCY=3
MAX_RETRIES=3
LLM_TIMEOUT_MS=60000

# ---------------------------------------------------------------------------
# Upload limits.
# ---------------------------------------------------------------------------

MAX_FILE_SIZE_BYTES=5242880
MAX_ROWS=5000
